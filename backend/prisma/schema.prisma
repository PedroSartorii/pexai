generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(uuid())
  name      String
  email     String    @unique
  password  String
  createdAt DateTime  @default(now())
  processes Process[]
  clients   Client[]
  qualifications Qualification[]
  processTitles  ProcessTitle[]
  juizos  Juizo[]
  acoes  Acao[]
  processos  Processo[]
  kanbanCards  KanbanCard[]
  licenca          Licenca?
  resetToken       String?
  resetTokenExpiry DateTime?
}

model Process {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  authorName     String
  defendantName  String
  cpfCnpj        String
  vara           String
  caseValue      Float
  narrative      String
  structuredData Json
  generatedText  String
  createdAt      DateTime @default(now())
}

model Client {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])

  // Tipo de pessoa jurídica ou física
  tipoPessoa        PessoaType

  // Dados pessoais ou empresariais
  nome              String   // Nome completo ou razão social
  cpfCnpj           String   @unique
  rgInscricaoEstadual String?

  // Qualificação
  estadoCivil       String?
  profissao         String?

  // Contatos
  email             String?
  telefoneCelular   String?
  telefoneFixo      String?

  // Endereço
  cep               String?
  logradouro        String?
  numero            String?
  complemento       String?
  bairro            String?
  cidade            String?
  uf                String?

  // Dados bancários opcionais (pode ser JSON para flexibilidade)
  dadosBancarios    Json?

  createdAt         DateTime @default(now())
  processosCliente  ProcessoCliente[]
} 

enum PessoaType {
  FISICA
  JURIDICA
}

model Qualification {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  nome        String
  descricao   String?
  polo        PoloType
  createdAt   DateTime @default(now())
  processosCliente  ProcessoCliente[]
}

enum PoloType {
  ATIVO
  PASSIVO
  OUTROS
}

enum AreaDireito {
  CIVIL
  TRABALHISTA
  PENAL
  TRIBUTARIO
  ADMINISTRATIVO
  PREVIDENCIARIO
  CONSUMIDOR
  FAMILIA
  EMPRESARIAL
  AMBIENTAL
  OUTROS
}

enum Prioridade {
  BAIXA
  MEDIA
  ALTA
  URGENTE
}

model ProcessTitle {
  id          String      @id @default(uuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  titulo      String
  areaDireito AreaDireito
  prioridade  Prioridade
  createdAt   DateTime    @default(now())
}

enum Instancia {
  PRIMEIRA
  SEGUNDA
  SUPERIOR
}

model Juizo {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  tribunal      String
  comarca       String
  instancia     Instancia
  orgaoJulgador String
  cep           String?
  logradouro    String?
  numero        String?
  complemento   String?
  bairro        String?
  cidade        String?
  uf            String?
  createdAt     DateTime @default(now())
  processos  Processo[]
}

enum RitoProcessual {
  COMUM
  SUMARISSIMO
  ESPECIAL
}

model Acao {
  id                String         @id @default(uuid())
  userId            String
  user              User           @relation(fields: [userId], references: [id])
  nomeAcao          String
  fundamentacao     String?
  valorCausa        Float?
  rito              RitoProcessual
  createdAt         DateTime       @default(now())
  processos  Processo[]
}

enum AcessoType {
  PUBLICO
  PRIVADO
  ENVOLVIDOS
}

enum CustoTipo {
  CUSTAS
  HONORARIOS
  PERICIA
  DILIGENCIA
  OUTROS
}

model Processo {
  id              String              @id @default(uuid())
  userId          String
  user            User                @relation(fields: [userId], references: [id])
  pasta           String?
  titulo          String
  numeroProcesso  String?
  linkTribunal    String?
  objeto          String?
  valorCausa      Float?
  distribuidoEm   DateTime?
  valorCondenacao Float?
  observacoes     String?
  responsavel     String?
  acesso          AcessoType          @default(PRIVADO)
  movimentacao    String?
  honorarios      String?
  parcerias       String?
  prazos          String?
  generatedText   String?
  juizoId         String?
  juizo           Juizo?              @relation(fields: [juizoId], references: [id])
  juizoLivre      String?
  acaoId          String?
  acao            Acao?               @relation(fields: [acaoId], references: [id])
  acaoLivre       String?
  instancia       Instancia?
  clientes        ProcessoCliente[]
  envolvidos      ProcessoEnvolvido[]
  custos          CustoProcessual[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  kanbanCards  KanbanCard[]
  lancamentos  Lancamento[]
  repassess    Repasse[]
}

model ProcessoCliente {
  id             String         @id @default(uuid())
  processoId     String
  processo       Processo       @relation(fields: [processoId], references: [id], onDelete: Cascade)
  clienteId      String?
  cliente        Client?        @relation(fields: [clienteId], references: [id])
  clienteLivre   String?
  qualificacaoId String?
  qualificacao   Qualification? @relation(fields: [qualificacaoId], references: [id])
  qualLivre      String?
}

model ProcessoEnvolvido {
  id         String   @id @default(uuid())
  processoId String
  processo   Processo @relation(fields: [processoId], references: [id], onDelete: Cascade)
  nome       String
  papel      String?
  documento  String?
  contato    String?
}

model CustoProcessual {
  id         String    @id @default(uuid())
  processoId String
  processo   Processo  @relation(fields: [processoId], references: [id], onDelete: Cascade)
  descricao  String
  valor      Float
  data       DateTime
  tipo       CustoTipo
  pago       Boolean   @default(false)
  createdAt  DateTime  @default(now())
}

enum KanbanColuna {
  BACKLOG
  TRIAGEM
  PRODUCAO
  REVISAO
  AGUARDANDO
  PROTOCOLO
  CONCLUIDO
}

enum KanbanPrioridade {
  VERMELHO
  AMARELO
  VERDE
  AZUL
}

model KanbanCard {
  id          String           @id @default(uuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id])
  titulo      String
  descricao   String?
  coluna      KanbanColuna     @default(BACKLOG)
  prioridade  KanbanPrioridade @default(AZUL)
  prazoFatal  DateTime?
  responsavel String?
  processoId  String?
  processo    Processo?        @relation(fields: [processoId], references: [id])
  ordem       Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

enum HonorarioStatus {
  PAGO
  PENDENTE
  ATRASADO
}

model Lancamento {
  id              String           @id @default(uuid())
  processoId      String
  processo        Processo         @relation(fields: [processoId], references: [id], onDelete: Cascade)
  valorTotal      Float
  status          HonorarioStatus  @default(PENDENTE)
  dataVencimento  DateTime
  dataRecebimento DateTime?
  descricao       String?
  createdAt       DateTime         @default(now())
}

model Repasse {
  id         String   @id @default(uuid())
  processoId String
  processo   Processo @relation(fields: [processoId], references: [id], onDelete: Cascade)
  parceiro   String
  percentual Float
  pago       Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Licenca {
  id         String    @id @default(cuid())
  codigo     String    @unique
  usada      Boolean   @default(false)
  usadaPor   User?     @relation(fields: [userId], references: [id])
  userId     String?   @unique
  criadaEm   DateTime  @default(now())
  ativadaEm  DateTime?
}